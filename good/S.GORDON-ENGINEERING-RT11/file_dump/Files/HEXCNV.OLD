	DIMENSION NDATA(17),INDATA(17),IADRS(17),IADRFL(17)
	BYTE FILNAM(15)
9999	TYPE 1
1	FORMAT(X'PROGRAM TO READ A HEX DUMP FILE CREATED BY X8085 AND
	1 CONVERT TO'/X'FORMAT PRODUCED BY DR11.FOR EPROM READER
	2 PROGRAM'/X'(USUAL FILEXT IS ''.HEX''')
C
C
C
C
	TYPE 9
9	FORMAT (X'ENTER INPUT FILENAME AS (EG.) MYPROG.HEX<CR>')
	ACCEPT 10,NCH,(FILNAM(I),I=1,14)
10	FORMAT (Q,80A1)
	DO 12,I=NCH+1,15
12	FILNAM(I)=0		!ASCII NULL.
	OPEN (UNIT=12,NAME=FILNAM,TYPE='OLD',READONLY)	!ERR=3000 DEL'D
C
C
	TYPE 15
15	FORMAT (X'DO YOU WANT DISK FILE (10) OR TERMINAL (7) OR
	1 PRINTER (6) OUTPUT ?')
	ACCEPT 18,LUNOUT
18	FORMAT (I6)
	IF (LUNOUT.NE.10)GO TO 30
	TYPE 19
19	FORMAT (X'ENTER FILENAME AS (EG.) MYPROG.ROM<CR>')
	ACCEPT 20,NCH,(FILNAM(I),I=1,14)
20	FORMAT (Q,80A1)
	DO 22,I=NCH+1,15
22	FILNAM(I)=0		!ASCII NULL.
	OPEN (UNIT=10,NAME=FILNAM,TYPE='NEW',ERR=3000)
C
C
C***************************************************************
C NOW CHECK THE INPUT FILE FOR SIZE SO AS TO MAP TO MEMORY
C AS REQUIRED INCLUDING 'FF'S OR '00'S FOR UNSPECIFIED BYTES.
C
30	N=1		!INITIALISE RECORD COUNTER AND READ FIRST:
C
100	READ (12,1000,ERR=150,END=200)NCOLON,NBYTE,NADDHI
	1,NADDLO,NDELIM,(NDATA(I),I=1,17)
1000	FORMAT (A1,4A2,17A2)!IF LESS THAN 16 DATABYTESPLUSCHECKSUM
C		!THEN CHECKSUM IS LAST NON-BLANK ARRAY ELEMENT,
C		!REMAINDER UP TO NDATA(17) RETURN 020040(8)
C		!(OCTAL FOR <SP><SP>).
C
D	TYPE 1001,NCOLON,NBYTE,NADDHI,NADDLO,NDELIM,
D	1 (NDATA(I),I=1,17)
D1001	FORMAT (A1,4A2,17A2,'RECORD END')
D	TYPE 1002,NDATA(16),NDATA(17)
D1002	FORMAT(X'NDATA(16)=',I6,'NDATA(17)=',I6)
D	PAUSE 'CHECK ROW FOR AGREEMENT WITH FILE, THEN <CR>'
C
C
C	CHECK FOR VALID RECORD PREAMBLE OF <SP><:>
C
	IF(NCOLON.EQ.8250)GO TO 150 ! <SP>: PACKED IN 16 BITS.
	TYPE 1005	!(IF RECORD NOT RECOGNISED BY COLON)
1005	FORMAT(X'**** THE INPUT FILE CHOSEN DOES NOT BEGIN
	1 RECORDS CORRECTLY.'/X'CHECK FILE/FILESPEC.'
	2/X'X8085 PRODUCES MYPROG.HEX WITH RECORDS STARTING
	3 WITH <SPACE><COLON>. ****')
	GO TO 9999		!BACK TO BEGINNING.
C
C
C	FIND HOW MANY BYTES AND ADDRS UPPER AND LOWER BOUNDS
C	IN THIS RECORD.
C
150	CALL HXDEC2(NBYTE,NDBYTE)	!GET DECIMAL NO OF BYTES
	IF(NDBYTE.EQ.0)GO TO 200	!MEANS LAST (NULL) RECORD.
	CALL HXDEC2(NADDHI,NDADHI)	!CONV. ROW BASE ADDRS TO
	CALL HXDEC2(NADDLO,NDADLO)	!DECIMAL INTEGERS (0,255).
	CALL D2TODF(NDADHI,NDADLO,NN1,NN1FL)!(AND THEN TO I/IFL).

C
C
C
C	ADD RECORD BASE ADDRESS TO NO. OF BYTES TO GET UPPER BOUND:
C
C
	NTOPHI=0
	NTOPLO=NDBYTE+NDADLO-1		!FORM TOP ADRS LOWER DIGS.
155	IF(NTOPLO.LT.256)GO TO 160	!-1 AS START IS FIRST LOCN.
C******??????!!!!!!!!!@@@@@@@@//////CHECK DR11.FOR DID THIS OK!!??
	NTOPLO=NTOPLO-256		
	NTOPHI=NTOPHI+1
	GO TO 155
160	NTOPHI=NTOPHI+NDADHI		!FORM TOP ADRS UPPER DIGS.
	CALL D2TODF(NTOPHI,NTOPLO,NNN,NNNFL)!(TOP OF RECORD ONLY).
C

C	NOW HAVE RECORD START ADDRESS (NDADHI,NDADLO)/(NN1,NN1FL)
C	 "   "     "    LAST  ADDRESS (NTOPHI,NTOPLO)/(NNN,NNNFL)
C	....IN DECIMAL PAIRS [0,255],[0,255] AND (I,IFL) FORMATS.
C
C
C	INITIALISE GLOBAL BOUND ACCUMULATORS IF ONLY 1ST RECORD READ.
C
165	IF(N.GT.1)GO TO 170	!GO UPDATE GLOBAL BOUND VARIABLES;
C				!ELSE INITIALISE BOUND ACCUMULATORS:
C
C 	NBOTHH=NADDHI	!BOTTOM ADDRESS HEX DIGIT PAIRS
C	NBOTLH=NADDLO	!SET ASIDE FROM FIRST RECORD ONLY.
C	NBOTHD=NDADHI	!BOT ADRS DECIMAL NO. PAIRS
C	NBOTLD=NDADLO	!FROM FIRST RECORD.	
C
	N0  =NN1
	N0FL=NN1FL
	NT  =NNN
	NTFL=NNNFL
	GO TO 190	!IF FIRST RECORD, DONT UPDATE GLOBAL BOUNDS.
C
C
C
C	CHECK/UPDATE GLOBAL BOUNDS USING SUBROUTINE ARITIF.
C
170	CALL ARITIF(NSIGN1,N0,N0FL,NN1,NN1FL,NT,NTFL)!CHECK RECORD
C				LOWER BOUND AGAINST GLOBAL BOUNDS.
	CALL ARITIF(NSIGNN,N0,N0FL,NNN,NNNFL,NT,NTFL)!CHECK RECORD
C				UPPER BOUND AGAINST GLOBAL BOUNDS.
C	(RECALL ARITIF RETURNS NSIGN=-1 IF BELOW, =0 IF IN BOUND
C		BUT NOT AT TOP, =1 IF AT TOP BOUND, =+2 ABOVE TOP).
C
C	********?????????NEVER BOTHERED TO LOOK AT NSIGNN - WHY WAS
C	@@@@@@@@@@@@@@@@@IT GENERATED? COULD USE TO DECIDE WHETHER
C	*****************TO UPDATE GLOBAL UPPER BOUND IF NOT ABORTING
C	*****************ON ERROR AS AT PRESENT. UNSOPHISTICATED.
C
	IF(NSIGN1.GT.1)GO TO 180	!ENTIRELY ABOVE PREVIOUS
C		RECORD UPPER BOUNDS SO GO UPDATE UPPER BOUND.
	TYPE 1008,N,NADDHI,NADDLO	!ELSE WARN OPERATOR.
1008	FORMAT(/X'***RECORD ',I6,' WITH BASE ADDRESS ',2A2,
	1/X'H OVERLAPS LOWER DATA - WARNING********',/)
	GO TO 9999			!AND RESTART.
C
C
C
C	UPDATE UPPER BOUND:
C
180	NT=NNN
	NTFL=NNNFL
C
C
190	N=N+1
	GO TO 100	!RETURN TO READ NEXT RECORD.
C
C
C
C	ALL RECORDS READ SO CALCULATE ROM SIZE
C
200	CONTINUE	!JUMPED HERE ON READING LAST (NULL) RECORD.
C
C	NOW FORM MEMORY SIZE FROM (TOP - BOTTOM ADDRESS + 1)
	NSIZHI=NTOPHI-NBOTHD	!WE JUST EXITED WITH TOP RECORD.
	NSIZLO=NTOPLO-NBOTLD + 1
	IF (NSIZLO.NE.256)GO TO 240
	NSIZLO=NSIZLO-256	!CARRY (IF NTOPLO-NBOTLD+1=256)
	NSIZHI=NSIZHI+1		!
240	IF (NSIZLO.GE.0)GO TO 250
	NSIZLO=NSIZLO+256	!BORROW (IF NBOTLD>NTOPLO)
	NSIZHI=NSIZHI-1		!
	GO TO 240		!
250	IF (NSIZHI.LT.0)TYPE 1016
1016	FORMAT (X'***********!!NEGATIVE MEMORY SIZE!!************')
C
C	NOW GET TOP AND SIZE INTO HEX DIGITS FOR DISPLAY:
	CALL DECHX2(NBOTHD,NBOTHH)
	CALL DECHX2(NBOTLD,NBOTLH)
	CALL DECHX2(NTOPHI,NTOPHH)
	CALL DECHX2(NTOPLO,NTOPLH)
	CALL DECHX2(NSIZHI,NSIZHH)
	CALL DECHX2(NSIZLO,NSIZLH)
	TYPE 1020,NBOTHH,NBOTLH,NTOPHH,NTOPLH,NSIZHH,NSIZLH
1020	FORMAT (X'INPUT FILE HAS LOWEST ADDRESS OF: ',2A2
	1,/X'AND HIGHEST BYTE ADDRESS OF: ',2A2,/X'A TOTAL
	2 MEMORY SPACE OF ',2A2,' IN HEXADECIMAL.'/
	3/X'USE THIS IN SETTING TARGET ROM ADDRESS AND
	4 SIZE.'//X'WHAT FILLER VALUE DO YOU WISH TO USE
	5 FOR UNSPECIFIED BYTES (AS EG:  FF<CR>) ?')	
	ACCEPT 1030,NFILL
1030	FORMAT (A2)
C
C*************************************************************
C	NOW WE SET TARGET PROM PARAMETERS.
C
400	TYPE 1100
1100	FORMAT (X'ENTER HEX ADDRESSES AS FOLLOWS AS UP TO FOUR
	1 CHARACTERS FROM [0,9] OR [A,F] FOLLOWED BY <CR>.')
	TYPE 1110
1110	FORMAT(X'ROM BOTTOM ADDRESS = ?'$)
	CALL HXIN4(NBOT,NUFLOB)
	TYPE 1120
1120	FORMAT (X'MEMORY SIZES'/X' 400 (1k x 8): 1702'/X' 800 (2k x 8)
	1: 2716'/X'1000 (4k x 8): 2732'/X'2000 (8k x 8): 2764'
	2/X'4000 (16k x 8): 27128'/X'SIZE FOR THIS ROM = ?'$)
	CALL HXIN4(NSIZ,NUFLOS)
C	  SINCE NSIZ AND NBOT LIE IN RANGE -32767-1 (0000) TO +32767
C	  (FFFF) WE CANNOT ADD THEM DIRECTLY.
	NOVBOT=0
	NOVSIZ=0
	IF (NBOT.GE.O.AND.NSIZ.GE.0)GO TO 400	!ABORT ENTRY.
	IF (NBOT.GE.0)NOVBOT=1
	IF (NSIZ.GE.0)NOVSIZ=1
	NTOP=(NSIZ-32767*NOVSIZ)+32767+(NBOT-32767*NOVBOT)!ORDER OF
	NTOP=NTOP+32767*(NOVSIZ+NOVBOT)	!THESE STATEMENTS VITAL TO
	NTOP=NTOP+NUFLOS+NUFLOB		!AVOID ENCOUNTERING +/-32768
C
	NUFLOT=0	!NTOP ASSUMED ALWAYS ABOVE 0000H.
C
	CALL HXOUT4(NTOPUH,NTOPLH,NTOP,NUFLOT)
C
D	TYPE 1300,M,MFL,NBOT,NUFLOB,NTOP,NUFLOT,IADRS
C
	TYPE 1130,NTOPUH,NTOPLH
1130	FORMAT (X'TOP WILL BE AT ',A2,A2,'    ENTER <CR> IF OK OR 1
	1 TO RERUN:')
	ACCEPT 1140,NTEST
1140	FORMAT (I1)
	IF (NTEST.NE.0)GO TO 400
C
C
C*******************************************************************
C	NOW WE REWIND THE INPUT FILE AND CARRY OUT THE CONVERSION
C
	REWIND 12
C
C
C		SET WRITE RECORD ADDRESS COUNTER  M  TO ROM BOTTOM.
C
	M=NBOT		!TRUE OUTPUT ADDRESS = M+NCOL"+MFL"
	MFL=NUFLOB
	NCOL=1		!OUTPUT RECORD BYTE INDEX.
	INCOL=1	!INPUT RECORD BYTE INDEX.
C
C			!READ FIRST RECORD
C
500	READ (12,1151,ERR=3030,END=3040)NCOLON,NBYTE,NADDHI,
	1NADDLO,NDELIM,(INDATA(I),I=1,17)
1151	FORMAT (A1,4A2,17A2)	!AS BEFORE.
	IF(NCOLON.EQ.8250)GO TO 510 ! <SP>: PACKED IN 16 BITS.
	TYPE 1005	!(IF RECORD NOT RECOGNISED BY COLON)
510	CALL HXDEC2(NBYTE,NDBYTE)	!GET DECIMAL NO OF BYTES
C
	IF(NDBYTE.NE.0)GO TO 512	
	TYPE 1160			!ELSE NULL FILE??????
1160	FORMAT(X'INPUT FILE FIRST RECORD BEGINS WITH
	1   :00 IE IT IS A NULL FILE.'/X'PROGRAM WILL
	2 PRODUCE AN OUTPUT FILE ENTIRELY OF FILLERS!!'
	3/X'****** CHECK INPUT FILE CONTENTS. ******')

C
512	CALL HXDEC2(NADDHI,NDADHI)	!CONV. ROW BASE ADDRS TO
	CALL HXDEC2(NADDLO,NDADLO)	!DECIMAL INTEGERS (0,255).
	CALL D2TODF(NDADHI,NDADLO,N,NFL)!AND CHANGE FORMAT.
C
C
C		FORM ARRAYS OF INPUT RECORD ADDRESS/DATA:
C
	DO 515,I=1,NDBYTE	!ADDRESS ARRAY [IADRS/IADRFL]
	IADRFL(I)=0		
	IADRS(I)=N+I-1
515	IF(N.EQ.-32767 .AND. NFL.EQ.-1 .AND. I.GE.2)
	1 IADRS(I)=N+I-2
	IADRFL(1)=NFL
C
	IADRFL(NDBYTE+1)=+2	!USE IADRFL=2 AS FLAG FOR BYTE
C				BEYOND ACTUAL END OF DATA.
C
C
D	DO 518,L=1,17
D517	FORMAT(X'NDBYTE,L,IADRS(L),IAD1FL,INDATA(L)'
D	1,I4,I4,I6,I3,A3)
D518	TYPE 517,NDBYTE,L,IADRS(L),IAD1FL,INDATA(L)
C
C	   PRELOAD OUTPUT ARRAY WITH SELECTED FILL CHARACTERS:
C
	NDONE=0		!(FLAG TO LATER INDICATE INPUT EXHAUSTED)
520	DO 521, I=1,16		!(NDATA(17)MAYBE LOADED ELSEWHERE)
521	NDATA(I) = NFILL
C
C		LOOK FOR MATCHING INPUT ADRESS HOLDING DATA:
C
530	IF(M.NE.IADRS(INCOL)
	1 .OR. (M.EQ.-32767.AND.MFL.NE.IADRFL(INCOL))
	1 .OR. NDONE.EQ.1) GO TO 540
	NDATA(NCOL)=INDATA(INCOL)!TRANSFER DATA(ADDRESSES MATCH)
	INCOL=INCOL+1				!INC INPUT POINTER
	IF (INCOL.EQ.17)GO TO 570		!AND CHECK IF
	IF (IADRFL(INCOL).EQ.2)GO TO 570!RECORD FINISHED(REFER
C		!STMT (515+3) AND (587+3) FOR FLAG SET =2)
C
C		!INCREMENT OUTPUT ADDRESS POINTER:
C
540	NCOL=NCOL+1		!POINT TO NEXT OUTPUT BYTE.
	IF (M.EQ.32767)GO TO 550!PRECAUTION AGAINST OFLO; DONT
	M=M+1	!INCREMENT; ASSUME NO MORE ADDRESSABLE DATA EXISTS.
	M=M+MFL		!ALLOW FOR TRANSITION FROM VERY ZERO.
	MFL=0		!MUST BE ABOVE ADDRESS ZERO BY NOW.
C
C
550	IF (NCOL.LT.17)GO TO 530	!GO FIND MORE DATA.
C
C		ELSE:-
C	   -----------------------------------
C	   WRITE A RECORD TO THE OUTPUT DEVICE
C	   ___________________________________
C
C	RECALL THAT ROW ADDRESS = INPUT ADDRESS + MEMBOT OFFSET
C		AND GET INPUT FILE DERIVED ROW ADDRESS (MODULO 16)
C
	K=0			!FLAG FOR CLEANUP AFTER LINE
	IF (M.EQ.32767)K=1	!540+1 OVERFLOW PRECAUTION.
	NRWFLO=0		![NROW,NRWFLO] IS O/P RECRD BASE ADR
	IF ((M-15).EQ.-32767)NRWFLO=-1	!DONT UNDERFLOW BELOW 000H
	NROW=M-NRWFLO			!SO ADD PIECEWISE BEFORE
	NROW=NROW-16+K		!GOING TO FORM ADRS AT RECORD START.
C
C
CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
C                         BUNK!
C
CC	ADD OUTPUT FILE BASE ADDRESS OFFSET TO INPUT DERIVED ADDRESS
CC		ROMBOT(MEMBOT)=[NBOT,NUFLOB] IS OFFSET.
C	IF (NUFLOB.EQ.-1)GO TO 560	!0000H OFFSET SO DONT ADD.
C	IF (NBOT.LE.0 .AND. NROW.LE.0)NROW=NROW+32767+NBOT  !WHAT A
C	IF (NBOT.LT.0 .AND. NROW.GT.0)NROW=(NBOT+32767)+NROW!TANGLED
C	IF (NBOT.GT.0 .AND. NROW.LT.0)NROW=(NROW+32767)+NBOT!WEB WE
C	NROW=NROW+NRWFLO+NUFLOB				    !WEAVE!
560	CALL HXOUT4(NROWU,NROWD,NROW,NRWFLO)
	WRITE (LUNOUT,1200)NROWU,NROWD,(NDATA(I),I=1,16)
1200	FORMAT (X,2A2,16(' ',A2))
CC
CC
D	TYPE 1300,M,MFL,NBOT,NUFLOB,NTOP,NUFLOT,IADRS
D1300	FORMAT(X'M , MFL ,NBOT,NBOF,NTOP,NTOF
D	1,((32767+IADRS(I),I=1,17)'/X
D	2I6,I2,I6,I2,I6,I2,'[',17I3,']')
C
CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC
C
	IF(M.GE.NTOP)GO TO 650	!IF THIS WAS LAST RECORD, CLOSE OFF.
	NCOL=1
	GO TO 520		!ELSE GO PREPARE A NEW O/P RECORD.
C
C-----------------------------------------------------------------
C
C	   INPUT RECORD IS EXHAUSTED, GET A NEW ONE.
C
570	INCOL=1		!RESET INPUT DATA COLUMN INDEX.
C
580	READ (12,1151,ERR=3030,END=3040)NCOLON,NBYTE,NADDHI,
	1NADDLO,NDELIM,(INDATA(I),I=1,17)
	IF(NCOLON.EQ.8250)GO TO 585 ! <SP>: PACKED IN 16 BITS.
	TYPE 1005	!(IF RECORD NOT RECOGNISED BY COLON)
	GO TO 3200	!AND GET OUT OF HERE.
585	CALL HXDEC2(NBYTE,NDBYTE)	!GET DECIMAL NO. BYTES
	IF (NDBYTE.EQ.0)GO TO 600	!LAST RECORD (NULL)
C
586	CALL HXDEC2(NADDHI,NDADHI)	!CONV. ROW BASE ADDRS TO
	CALL HXDEC2(NADDLO,NDADLO)	!DECIMAL INTEGERS (0,255).
	CALL D2TODF(NDADHI,NDADLO,N,NFL)!AND CHANGE FORMAT.
C
C		FORM ARRAYS OF INPUT RECORD ADDRESS/DATA:
C
	DO 587,I=1,NDBYTE	!ADDRESS ARRAY [IADRS/IADRFL]
	IADRFL(I)=0		
	IADRS(I)=N+I-1
587	IF(N.EQ.-32767 .AND. NFL.EQ.-1 .AND. I.GE.2)
	1 IADRS(I)=N+I-2
	IADRFL(1)=NFL
C
	IADRFL(NDBYTE+1)=+2	!USE IADRFL=2 AS FLAG FOR:
C				<PREVIOUS BYTE WAS LAST>.
C
	GO TO 540	!GO BACK WITH NEW DATA.
C
C
C	      COME HERE IF INPUT FILE IS EXHAUSTED;
C	  - NOW LOAD REMAINDER OF O/P WITH <DONT CARE>'S (NFILL'S)
C	
C***600	IF (M.EQ.NTOP)GO TO 650		!NO FILLS REQ'D, CLOSE OFF.
600	NDONE=1				!FLAG THAT INPUT FINISHED;
	GO TO 540			!RELOOP FOR NFILL TIL TOP.
C
C
C		NOW CLOSE OFF OUTPUT AND RESTART PROGRAM.
C
650	IF (LUNOUT.NE.10)GO TO 3200
	CLOSE (UNIT=10,ERR=3010)
	GO TO 3200
3000	TYPE 3001
3001	FORMAT (X'FAILED TO OPEN DISK FILE')
	GO TO 3200
3010	TYPE 3011
3011	FORMAT (X'FAILED TO CLOSE DISK FILE')
	GO TO 3200
3020	TYPE 3021,NERROR
3021	FORMAT (X'ERROR',I2,' OCCURRED')
	GO TO 3200
3030	TYPE 3031
3031	FORMAT (X'ERROR READING INPUT FILE')
	GO TO 3200
3040	TYPE 3041
3041	FORMAT (X'ERROR - EOF READ BEFORE FORMAL END OF DATA')
3200	TYPE 3201
3201	FORMAT(X'+++++++++++++++CLOSING (?) INPUT FILE++++++++++++++++')
	CLOSE (UNIT=12,ERR=3010)
	GO TO 9999
C
C
C	HEXADECIMAL UTILITY SUBROUTINES  Author S. A. Gordon
C	     For use by HEXCNV, DR11 ROM Utility Packages
C
C	Remember to link it: HEXUTL.OBJ
C	-Includes:
C	HXDEC1
C	ALPHEX
C	HXDEC2
C	DECHX2
C	HXOUT4
C	HXIN4
C	ARITIF
C	D2TODF
C	-------------------------------------
	STOP
	END

␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀