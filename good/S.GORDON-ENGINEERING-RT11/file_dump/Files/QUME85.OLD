;
;*************************************************************
; DIAGNOSTIC ROUTINES 
;
ERR1:	NOP	;@@@
;
;
; SUBROUTINE CHKROM - <ADD>'S all bytes from (ROMTOP) down
; to (0000H) including the checksum in 2's complement stored
; in the vector area at ROMSUM. If the total sum is non-zero,
; CHKROM sets bit 7 in port 40 (ERRORS) and sets the system
; state SYSTAT bit 7 (Error).
;
; Requires constant ROMTOP to be defined.
CHKROM:   LXI   H,ROMTOP        ;Point to top ROM byte.
          MVI   B,00H           ;and clear B reg.
MOROM:    MOV   A,B             ;Recover subtotal.
          ADD   M               ;ADD current byte and
          MOV   B,A             ;put subtotal aside.
          DCX   H               ;Point to next byte.
          MOV   A,H             ;Check if HL
          ORA   L               ;down to 0000H yet
          JNZ   MOROM           ;continue loop if not.
          MOV   A,B             ;Else restore subtotal
          ADD   M               ;and add bottom byte
          RZ                    ;Exit if Zero total(ROM OK)
;
          MVI   A,80H           ;set bit 7 in ERRORS port
          CALL  ERROR           ;and set SYSTAT bit 7.
          RET                   ;
;
;
;
;
;
; SUBROUTINE CHKRWM - Checks integrity of read/write
; memory (IE. "RAM").   Complements twice all bytes from
; (MEMST) up to (MEMST + MEMSIZ) checking for bit
; failures.
; If a failure is detected, CHKRWM sets bit 6 in port 40
; ERRORS: BADRWM; and sets the system state byte SYSTAT
; bit 7 (Error).
;
CHKRWM:   LXI   H,MEMST         ;Get RAM bottom address
          LXI   B,MEMSIZ        ;and size
NXTRWM:   MOV   A,M             ;Get byte and
          MOV   D,A             ;set aside in D.
          CMA                   ;Complement and
          MOV   M,A             ;store.
          CMP   M               ;Did complement store?
          JNZ   BADRWM          ;Faulty if not identical
          MOV   M,D             ;Rewrite original data.
          MOV   A,D             ;and also put it in A register.
          CMP   M               ;Does it read correctly?
          JNZ   BADRWM          ;Faulty if not identical
          INX   H               ;else point to next byte
          DCX   B               ;decr. byte count
          MOV   A,B             ;Check if BC (byte count)
          ORA   C               ;down to 0000H yet
          RZ                    ;Return if so,
          JMP   NXTRWM          ;Else loop.
;
BADRWM:   MOV   M,D             ;Attempt to restore data.
          MVI   A,40H           ;set bit 6 in ERRORS port
          CALL  ERROR           ;and set SYSTAT bit 7 (error)
          RET                   ;
;
;
;
;
;
;
; SUBROUTINE WATCH1  -  Turns on watchdog bit 0 in ERRORS
; port. Called from ????? 
;
WATCH1:   LXI   H,ERRBUF        ;ERRORS buffer
          MOV   A,M             ;Read,
          ORI   01H             ;Set bit 0 on.
          MOV   M,A             ;and rewrite buffer
          OUT   ERRORS          ;and port.
          RET                   ;
;
;
;
; SUBROUTINE WATCH0  -  Turns off watchdog bit 0 in ERRORS
; port. Called from ????????????
;
WATCH0:   LXI   H,ERRBUF        ;ERRORS buffer
          MOV   A,M             ;read,
          ANI   0FEH            ;mask off bit 0
          MOV   M,A             ;and rewrite buffer
          OUT   ERRORS		;and port.
          RET                   ;
;
;
;
;
; SUBROUTINE ERROR - Receives error identification in
; register A, indicates all notified errors in ERRORS
; port 40 and sets the system state SYSTAT bit (7).
;
ERROR:	PUSH H			;Free HL for use.
	LXI H,ERRBUF		;ERROR buffer
	ORA M			;Add bit(s) from reg. A
	MOV M,A			;rewrite buffer and
	OUT ERRORS		;error display port.
	LXI H,SYSTAT		;Get system state
	MOV A,M			;
	ORI 80H			;and set bit 7 (Error).
	MOV M,A			;
	POP H			;Restore HL.
	RET			;
;
; SUBROUTINE TRACE - Debug routine similar to subroutine ERROR.
; Receives waypoint identification bit in register A, indicates
; waypoint in DEBUGS port 41 for 25 ms each and clears before
; continuing.
TRACE:    PUSH  H               ;release HL for use.
          LXI   H,BUGBUF        ;buffer to DEBUGS port
          ORA   M               ;Add with waypoint bit in reg. A
          OUT   DEBUGS		;Load port only for tmp. display.
          MVI   A,09H           ;calls for 2.5 x 10 ms = 25 ms
TRACE2:   CALL  TDLAY2          ;of delay routine 2.
          DCR   A               ;
          JNZ   TRACE2          ;
          MOV   A,M             ;Get original buffered contents.
          OUT   DEBUGS		;and reload port (clear waypoint)
          POP   H               ;Restore HL.
          RET                   ;
;
;
;
;TIME DELAY SUBROUTINE(S)
;
;
TDLAY1:	PUSH D
	MVI     D,0FFH     ; delay loop TDLAY1 is 298ms @ 6144kHz XTAL
        JMP     WAIT
;
TDLAY2:	PUSH D
	MVI     D,01H     ; delay loop  TDLAY2 is 1.17ms @ 6144kHz XTAL
WAIT:	MVI     E,00H
        DCR     E
        JNZ     WAIT+2
        DCR     D
        JNZ    	WAIT+2
	POP	D
        RET
;
;
;   DELAYA - To delay by (80 x COUNTA) clk cycs (80cyc=26.04us,6144XTAL)
; 		1 => 80, 2 => 160, ...  FF=> 15x80, 00 => 16x80
;			;18;Call takes 18 cycles
DELAYA:	LDA COUNTA	;13;
	STA COUNTA	;13;Waste 13cyc		!WASTE 33 CYCLES
	STA COUNTA	;13;Waste 13cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
DELA:	DCR A		; 4; - (80 cyc loop while not RZ else last time 86cyc)
	RZ		;12/6; - Returned 80 cyc total if RZ first time.
	XTHL		;16; Waste 32		!WASTE 60 CYCLES
	XTHL		;16;  cycles		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	JMP DELA	;10; Loop
;
;   DELAYB - To delay by (80 x COUNTB) clk cycs (80cyc=26.04us,6144XTAL)
; 		1 => 80, 2 => 160, ...  FF=> 15x80, 00 => 16x80
;			;18;Call takes 18 cycles
DELAYB:	LDA COUNTB	;13;
	STA COUNTB	;13;Waste 13cyc		!WASTE 33 CYCLES
	STA COUNTB	;13;Waste 13cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
DELB:	DCR A		; 4; - (80 cyc loop while not RZ else last time 86cyc)
	RZ		;12/6; - Returned 80 cyc total if RZ first time.
	XTHL		;16; Waste 32		!WASTE 60 CYCLES
	XTHL		;16;  cycles		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	ANI 0FFH	; 7;Waste 7 cyc		!
	JMP DELB	;10; Loop
;
;
;
