;
;------------- LOOKUP TABLES ----------------------------------
;
	ORG	ROMTOP-30H
;
TIMTBL:	DB	TA300,TB300	;Baud timing counts table     12B
	DB	TA600,TB600	;
	DB	TA1K2,TB1K2	;
	DB	TA2K4,TB2K4	;
	DB	TA4K8,TB4K8	;
	DB	TA9K6,TB9K6	;9600 baud timing counts
;
FFTBL:	DW	FFLEN0		;Form length table.           16B
	DW	FFLEN1		;
	DW	FFLEN2		;
	DW	FFLEN3		;
	DW	FFLEN4		;
	DW	FFLEN5		;
	DW	FFLEN6		;
	DW	FFLEN7		;
;
PCHTBL:	DB	PCH0,PCH1,PCH2,PCH3	;Character pitch table 4B
;
SPCTBL:	DB	SPC0,SPC1,SPC2,SPC3	;Line spacing table    4B
;
        END
